# =============================================================================
# SCIM 2.0 服务环境变量配置示例
# =============================================================================
# 复制此文件为 .env 并根据需要修改：
#   cp .env.example .env
# =============================================================================

# =============================================================================
# 存储驱动配置（重要）
# =============================================================================
# 可选值：memory / redis / mysql / postgres / authing
# - memory: 内存存储，数据不持久化，重启后丢失，适合开发和测试
# - redis: Redis存储，高性能，适合缓存场景
# - mysql: MySQL存储，成熟稳定，适合生产环境
# - postgres: PostgreSQL存储，功能丰富，适合复杂查询
# - authing: Authing存储，基于Authing云服务
STORAGE_DRIVER=memory

# =============================================================================
# 服务端口配置
# =============================================================================
SCIM_PORT=8080
REDIS_PORT=6379
MYSQL_PORT=3306
POSTGRES_PORT=5432
ADMINER_PORT=8081
REDIS_COMMANDER_PORT=8082

# =============================================================================
# Redis 配置（当 STORAGE_DRIVER=redis 时使用）
# =============================================================================
REDIS_URI=redis://redis:6379/0

# =============================================================================
# MySQL 配置（当 STORAGE_DRIVER=mysql 时使用）
# =============================================================================
MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=scim
MYSQL_USER=scim
MYSQL_PASSWORD=scim_password
MYSQL_DSN=root:password@tcp(mysql:3306)/scim?charset=utf8mb4&parseTime=True&loc=Local

# =============================================================================
# PostgreSQL 配置（当 STORAGE_DRIVER=postgres 时使用）
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=scim
POSTGRES_DSN=host=postgres user=postgres password=postgres dbname=scim port=5432 sslmode=disable

# =============================================================================
# SCIM 服务配置
# =============================================================================
SCIM_MODE=release
SCIM_LOG_LEVEL=info
SCIM_TOKEN=aGCIhV2JtgAezYduMpE1rK6Omy

# =============================================================================
# Authing 存储配置（当 STORAGE_DRIVER=authing 时使用）
# =============================================================================
# 从 Authing 控制台获取
STORAGE_AUTHING_API_KEY=your-authing-api-key
STORAGE_AUTHING_APP_ID=your-authing-app-id
STORAGE_AUTHING_AUTH_URL=https://api.authing.cn
STORAGE_AUTHING_API_URL=https://api.authing.cn/v3

# =============================================================================
# Swagger 文档配置
# =============================================================================
SWAGGER_ENABLED=true
SWAGGER_PATH=/swagger
